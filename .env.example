# .env.example — copy to .env and fill secrets. DO NOT commit .env to VCS.
# These variables are required for both local development and Vercel/Cloudflare deployments.

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# TMDB (Server-side)
# Preferred: provide TMDB_READ_ACCESS_TOKEN (Bearer). TMDB_API_KEY is fallback.
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here
TMDB_API_KEY=your_tmdb_api_key_here

# Notes for Vercel:
# 1. Add these variables in Vercel Project Settings > Environment Variables.
# 2. Ensure VITE_ prefix is kept for client-side variables.
